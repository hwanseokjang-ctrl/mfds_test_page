# ---------------------------------------------------------------------------
# mfds_test_page LLM 연결 설정
# ---------------------------------------------------------------------------
# 이 파일은 템플릿입니다. 실제 값은 `.env` 에 복사해 넣으세요.
# `.env` 는 .gitignore 에 등록되어 있습니다.
# 두 키 중 최소 하나만 있어도 페이지 상단 LLM 설정 패널에서 해당 제공자를 고를 수 있습니다.
# 아무 키도 없으면 자동으로 "데모 Placeholder" 모드로 동작합니다.
# ---------------------------------------------------------------------------

# OpenAI (GPT 5.x 추론 모델)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1

# Google Gemini (2.5 추론 모델)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
